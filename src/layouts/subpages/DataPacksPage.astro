---
import {
  pageRoutes,
  type Locale,
  type SiteContent,
} from "../../i18n/content";
import SubPage from "../SubPage.astro";

interface Props {
  pageContent: SiteContent;
  locale: Locale;
}

const { pageContent, locale } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const withBasePath = (path: string) =>
  `${basePath.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
---

<SubPage locale={locale} currentPage="dataPacks" pageContent={pageContent}>
  <section class="scope section-band" aria-labelledby="data-pack-detail-title">
    <div class="section-inner scope-grid">
      <div class="scope-panel">
        <p class="kicker">{pageContent.dataPack.kicker}</p>
        <h2 id="data-pack-detail-title">{pageContent.dataPack.title}</h2>
        <p>{pageContent.dataPack.body}</p>
      </div>
      <a
        class="chapter-card chapter-link"
        href={withBasePath(pageRoutes[locale].chapterOne)}
      >
        <span>{pageContent.dataPack.chapter.kicker}</span>
        <h3>{pageContent.dataPack.chapter.title}</h3>
        <p>{pageContent.dataPack.chapter.body}</p>
        <ul aria-label={pageContent.dataPack.chapter.title}>
          {pageContent.dataPack.chapter.points.map((point) => <li>{point}</li>)}
        </ul>
      </a>
    </div>
  </section>
</SubPage>
