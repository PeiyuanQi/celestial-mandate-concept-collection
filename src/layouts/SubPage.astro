---
import SiteLayout from "./SiteLayout.astro";
import {
  type Locale,
  type SiteContent,
  type SitePage,
} from "../i18n/content";

type PageIntro = {
  kicker: string;
  title: string;
  body: string;
};

interface Props {
  pageContent: SiteContent;
  locale: Locale;
  currentPage: Exclude<SitePage, "home">;
  pageIntro?: PageIntro;
  currentPath?: string;
  localizedPaths?: Partial<Record<Locale, string>>;
}

const {
  pageContent,
  locale,
  currentPage,
  pageIntro: pageIntroOverride,
  currentPath,
  localizedPaths,
} = Astro.props;
const basePath = import.meta.env.BASE_URL;
const withBasePath = (path: string) =>
  `${basePath.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
type PageHeroImage = {
  src: string;
  width: number;
  height: number;
  alt: string;
};

const pageHeroImages: Record<Exclude<SitePage, "home">, PageHeroImage> = {
  gameplay: {
    src: "/images/hero-gameplay-relay-station.png",
    width: 1659,
    height: 948,
    alt: pageContent.gameplay.heroImageAlt,
  },
  dataPacks: {
    src: "/images/hero-data-packs-archive.png",
    width: 1672,
    height: 941,
    alt: pageContent.dataPack.heroImageAlt,
  },
  chapterOne: {
    src: "/images/hero-po-zhen-zi-southern-ming.png",
    width: 1672,
    height: 941,
    alt: pageContent.dataPack.chapter.heroImageAlt,
  },
  wiki: {
    src: "/images/hero-wiki-archive-index.png",
    width: 1672,
    height: 941,
    alt: pageContent.wiki.heroImageAlt,
  },
};

const pageHeroImage = pageHeroImages[currentPage];
const heroImagePath = withBasePath(pageHeroImage.src);
const defaultPageIntro = {
  gameplay: {
    kicker: pageContent.gameplay.kicker,
    title: pageContent.gameplay.title,
    body: pageContent.gameplay.body,
  },
  dataPacks: {
    kicker: pageContent.dataPack.kicker,
    title: pageContent.dataPack.title,
    body: pageContent.dataPack.body,
  },
  chapterOne: {
    kicker: pageContent.dataPack.chapter.kicker,
    title: pageContent.dataPack.chapter.title,
    body: pageContent.dataPack.chapter.body,
  },
  wiki: {
    kicker: pageContent.wiki.kicker,
    title: pageContent.wiki.title,
    body: pageContent.wiki.body,
  },
}[currentPage];
const pageIntro = pageIntroOverride ?? defaultPageIntro;
const pageTitle = `${pageIntro.title} | ${pageContent.meta.title}`;
---

<SiteLayout
  pageContent={pageContent}
  locale={locale}
  currentPage={currentPage}
  title={pageTitle}
  description={pageIntro.body}
  currentPath={currentPath}
  localizedPaths={localizedPaths}
>
  <main id="top" class="subpage-main">
    <section class="subpage-hero" aria-labelledby="subpage-title">
      <img
        class="hero-image"
        src={heroImagePath}
        width={pageHeroImage.width}
        height={pageHeroImage.height}
        alt={pageHeroImage.alt}
      />
      <div class="hero-shade" aria-hidden="true"></div>
      <div class="subpage-hero-content">
        <p class="eyebrow">{pageIntro.kicker}</p>
        <h1 id="subpage-title">{pageIntro.title}</h1>
        <p class="hero-copy">{pageIntro.body}</p>
      </div>
    </section>

    <slot />
  </main>
</SiteLayout>
