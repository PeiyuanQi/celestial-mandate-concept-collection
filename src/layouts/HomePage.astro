---
import SiteLayout from "./SiteLayout.astro";
import { type HomeContent, type Locale } from "../i18n/home";

interface Props {
  pageContent: HomeContent;
  locale: Locale;
}

const { pageContent, locale } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const withBasePath = (path: string) =>
  `${basePath.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const heroImagePath = withBasePath("/images/hero-command-table.png");
---

<SiteLayout pageContent={pageContent} locale={locale} currentPage="home">
  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <img
        class="hero-image"
        src={heroImagePath}
        width="1792"
        height="1024"
        alt={pageContent.hero.imageAlt}
      />
      <div class="hero-shade" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="eyebrow">{pageContent.hero.eyebrow}</p>
        <h1 id="hero-title">{pageContent.hero.title}</h1>
        <p class="hero-copy">{pageContent.hero.copy}</p>
        <div class="hero-actions" aria-label={pageContent.navAriaLabel}>
          {
            pageContent.hero.actions.map((action) => (
              <a class={`button ${action.variant}`} href={withBasePath(action.href)}>
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="intro section-band" aria-labelledby="intro-title">
      <div class="section-inner intro-grid">
        <div>
          <p class="kicker">{pageContent.intro.kicker}</p>
          <h2 id="intro-title">{pageContent.intro.title}</h2>
        </div>
        <p>{pageContent.intro.body}</p>
      </div>
    </section>
  </main>
</SiteLayout>
