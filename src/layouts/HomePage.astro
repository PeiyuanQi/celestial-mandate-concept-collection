---
import SiteLayout from "./SiteLayout.astro";
import { type HomeContent, type Locale } from "../i18n/home";

interface Props {
  pageContent: HomeContent;
  locale: Locale;
}

const { pageContent, locale } = Astro.props;
const basePath = import.meta.env.BASE_URL;
const withBasePath = (path: string) =>
  `${basePath.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
const heroImagePath = withBasePath("/images/hero-command-table.png");
---

<SiteLayout pageContent={pageContent} locale={locale} currentPage="home">
  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <img
        class="hero-image"
        src={heroImagePath}
        width="1792"
        height="1024"
        alt={pageContent.hero.imageAlt}
      />
      <div class="hero-shade" aria-hidden="true"></div>
      <div class="hero-content">
        <p class="eyebrow">{pageContent.hero.eyebrow}</p>
        <h1 id="hero-title">{pageContent.hero.title}</h1>
        <p class="hero-copy">{pageContent.hero.copy}</p>
        <div class="hero-actions" aria-label={pageContent.navAriaLabel}>
          {
            pageContent.hero.actions.map((action) => (
              <a class={`button ${action.variant}`} href={withBasePath(action.href)}>
                {action.label}
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="intro section-band" aria-labelledby="intro-title">
      <div class="section-inner intro-grid">
        <div>
          <p class="kicker">{pageContent.intro.kicker}</p>
          <h2 id="intro-title">{pageContent.intro.title}</h2>
        </div>
        <p>{pageContent.intro.body}</p>
      </div>
    </section>

    <section class="pillars" id="gameplay-preview" aria-labelledby="gameplay-preview-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="kicker">{pageContent.gameplay.kicker}</p>
          <h2 id="gameplay-preview-title">{pageContent.gameplay.title}</h2>
        </div>
        <div class="pillar-grid">
          {
            pageContent.gameplay.pillars.map((pillar, index) => (
              <article class="pillar-card">
                <span class="pillar-index">{String(index + 1).padStart(2, "0")}</span>
                <h3>{pillar.label}</h3>
                <p>{pillar.text}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="scope section-band" id="data-packs-preview" aria-labelledby="data-packs-preview-title">
      <div class="section-inner scope-grid">
        <div class="scope-panel">
          <p class="kicker">{pageContent.dataPack.kicker}</p>
          <h2 id="data-packs-preview-title">{pageContent.dataPack.title}</h2>
          <p>{pageContent.dataPack.body}</p>
        </div>
        <article class="chapter-card">
          <span>{pageContent.dataPack.chapter.kicker}</span>
          <h3>{pageContent.dataPack.chapter.title}</h3>
          <p>{pageContent.dataPack.chapter.body}</p>
          <ul aria-label={pageContent.dataPack.chapter.title}>
            {pageContent.dataPack.chapter.points.map((point) => <li>{point}</li>)}
          </ul>
        </article>
      </div>
    </section>

    <section class="collection" id="wiki-preview" aria-labelledby="wiki-preview-title">
      <div class="section-inner collection-grid">
        <div>
          <p class="kicker">{pageContent.wiki.kicker}</p>
          <h2 id="wiki-preview-title">{pageContent.wiki.title}</h2>
          <p>{pageContent.wiki.body}</p>
        </div>
        <div class="wiki-grid" aria-label={pageContent.wiki.categoriesAriaLabel}>
          {
            pageContent.wiki.categories.map((category, index) => (
              <section class="wiki-card" aria-labelledby={`wiki-preview-category-${index}`}>
                <h3 id={`wiki-preview-category-${index}`}>{category.label}</h3>
                <ul>
                  {category.items.map((item) => <li>{item}</li>)}
                </ul>
              </section>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
