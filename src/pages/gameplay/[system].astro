---
import GameplaySystemPage from "../../layouts/subpages/GameplaySystemPage.astro";
import { siteContent } from "../../i18n/content";

export function getStaticPaths() {
  return siteContent["zh-Hans"].gameplay.systems.map((system) => ({
    params: { system: system.slug },
    props: { system },
  }));
}

const { system } = Astro.props;
---

<GameplaySystemPage
  locale="zh-Hans"
  pageContent={siteContent["zh-Hans"]}
  system={system}
/>
